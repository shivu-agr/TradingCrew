# Copy this file to `.env` and fill in your own values.  `.env` is
# git-ignored — never commit real keys.

# =============================================================================
# Primary LLM — any OpenAI-compatible vLLM-style endpoint.  Preferred when
# all three values below are set.  Pick a long-context model (~131K) if
# you plan to use the full 8-analyst debate flow — the bull / bear /
# research-manager prompts include every analyst report and can easily
# reach 30-50K tokens before the LLM responds.
# =============================================================================
VLLM_LLM_BASE_URL=
VLLM_LLM_MODEL=
VLLM_LLM_API_KEY=

# =============================================================================
# Fallback LLM — local vLLM (only used if the VLLM_LLM_* vars above are
# unset).  Run e.g. `vllm serve <model> --port 8081 --tool-call-parser hermes`.
# OPENAI_API_KEY must be set to any non-empty string — vLLM's OpenAI-compatible
# server ignores the value but its client library requires the header.
# =============================================================================
LOCAL_LLM_BASE_URL=http://localhost:8081/v1
LOCAL_LLM_MODEL=
OPENAI_API_KEY=dummy

# Provider prefix used in the model string (CrewAI/LiteLLM convention):
#   hosted_vllm  -> vLLM-style server (default — both endpoints above are vLLM)
#   ollama_chat  -> local Ollama
#   openai       -> any other OpenAI-compatible server (needs litellm extra)
LLM_PROVIDER_PREFIX=hosted_vllm

# =============================================================================
# Closed-source LLM API keys (optional) — only required if you enable the
# corresponding preset in the UI's LLM dropdown.  The picker greys out
# closed-source options whose key isn't set, so leaving these blank just
# means those presets are unavailable.
# =============================================================================
# Used by `openai-gpt-4o-mini` and `openai-gpt-4o` UI presets.  Kept SEPARATE
# from OPENAI_API_KEY=dummy above (which the local vLLM client requires as a
# placeholder).
OPENAI_PROD_API_KEY=
# Used by `anthropic-claude-sonnet`.
ANTHROPIC_API_KEY=

# Default UI preset id (matches `trading_crew/llm_presets.py::BUILTIN_PRESETS`).
# Users can still override per-run via the sidebar dropdown.
TRADINGCREW_DEFAULT_LLM_PRESET=hosted-vllm-oss

# =============================================================================
# Embedding endpoint — used by CrewAI's native memory (short/long/entity).
# Required when memory is enabled, unless the user picks a closed-source
# embedding preset (e.g. `openai-text-embedding-3-small`) from the UI.
# Any OpenAI-compatible embedding server works.
# =============================================================================
VLLM_EMBEDDING_BASE_URL=
VLLM_EMBEDDING_MODEL=
VLLM_EMBEDDING_API_KEY=

# Per-document character budget passed to the embedder.  Small models like
# `embeddinggemma-300m` cap inputs at 2048 tokens.  Memory writes (PM
# rationale + analyst summaries) can exceed that and surface as a confusing
# "400 - maximum context length is 2048 tokens" right after the Portfolio
# Manager.  The default 6000 (~1500 tokens) keeps a safe margin; bump it
# only if you switch to a larger-window embedder (the OpenAI embedding
# presets ship 24000 as their default — that's a model-aware sensible
# value, but setting this env var clamps it tighter).
TRADINGCREW_EMBEDDER_MAX_CHARS=6000

# Default UI preset id for the embedding picker.  Matches
# `trading_crew/embedding_presets.py::BUILTIN_PRESETS`.
TRADINGCREW_DEFAULT_EMBEDDING_PRESET=vllm-embedding

# Max-workers for CrewAI's Memory save pool.  Default is 1 (serial) inside
# CrewAI itself, which queues every analyze call and turns a 5-min run into
# 30 min once you have 100+ saves.  Bumping to 8 lets concurrent
# `remember()` calls fan out so we can saturate the LLM's ~60 req/min
# budget instead of leaving 90 % of the latency on the table.
TRADINGCREW_MEMORY_SAVE_WORKERS=8

# --- News / web search ------------------------------------------------------
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Telemetry --------------------------------------------------------------
OTEL_SDK_DISABLED=true
CREWAI_DISABLE_TELEMETRY=true

# --- Web UI (optional) ------------------------------------------------------
TRADINGCREW_WEB_HOST=0.0.0.0
TRADINGCREW_WEB_PORT=8001
